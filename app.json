{
  "expo": {
    "name": "SAILY",
    "slug": "saily",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sail.png",
    "scheme": "newapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.newapp.privacy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sail.png",
        "backgroundColor": "#121212"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sail.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sail.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#121212",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf80de8c-d0fb-4657-b82f-c29a7a720084"
      }
    }
  }
}